<%# Public status/maintenance dashboard template. Keep comments in EJS form so they are not rendered to users. %>
<!DOCTYPE html>
<html lang="ja" data-bs-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>障害情報・メンテナンス情報お知らせサイト | 島根データセンター友の会</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body { background-color: var(--bs-body-bg); color: var(--bs-body-color); transition: background-color .3s, color .3s; }
    h1 { font-size: 2rem; font-weight: 600; }
    .tab-content { display: none; }
    .tab-content.active { display: block; }
    .incident-card, .maint-card {
      background: var(--bs-card-bg, #fff);
      border-radius: 1rem;
      box-shadow: 0 2px 6px rgba(0,0,0,.1);
      padding: 1.25rem;
      margin-bottom: 1rem;
      border: 1px solid rgba(0,0,0,.05);
    }
    [data-bs-theme="dark"] .incident-card,
    [data-bs-theme="dark"] .maint-card {
      background: #1f2329;
      border-color: #30363d;
      box-shadow: 0 2px 8px rgba(0,0,0,.35);
    }
    .truncate {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .content-area { max-width: 1200px; margin: 0 auto; }
    .filter-chip { cursor: pointer; }
    #activeFilters:empty { display: none !important; }
    .status-badge { color: #fff; }
    .meta-item { font-size: .9rem; color: var(--bs-secondary-color); }
    .last-updated { font-size: .9rem; color: var(--bs-secondary-color); }
    [data-bs-theme="dark"] .meta-item,
    [data-bs-theme="dark"] .last-updated {
      color: #b6c2cf;
    }
    [data-bs-theme="dark"] .truncate {
      color: #e6edf3;
    }
    [data-bs-theme="dark"] .incident-card h4,
    [data-bs-theme="dark"] .maint-card h4 {
      color: #e6edf3;
    }
    [data-bs-theme="dark"] .badge.bg-secondary {
      background-color: #495057 !important;
      color: #f8f9fa !important;
    }
    [data-bs-theme="dark"] .desktop-filter-panel .border,
    [data-bs-theme="dark"] .accordion-item {
      border-color: #30363d !important;
      background-color: #1f2329;
    }
    [data-bs-theme="dark"] .form-control,
    [data-bs-theme="dark"] .form-select,
    [data-bs-theme="dark"] .accordion-button {
      background-color: #0f1720;
      color: #e6edf3;
      border-color: #30363d;
    }
    [data-bs-theme="dark"] .accordion-button:not(.collapsed) {
      background-color: #16202a;
      color: #e6edf3;
    }
    .search-toolbar { display: flex; flex-wrap: wrap; gap: .5rem; align-items: center; }
    .search-input-wrap { flex: 1 1 520px; min-width: 240px; }
    .pager-summary { font-size: .875rem; color: var(--bs-secondary-color); }

    @media (max-width: 768px) {
      .content-area { max-width: 95%; }
      .desktop-filter-panel { display: none; }
      #desktopFilterToggle { display: none; }
      .mobile-filter-panel { display: block; }
    }
    @media (min-width: 769px) {
      .desktop-filter-panel { display: block; }
      .mobile-filter-panel { display: none; }
    }
  </style>
</head>
<body>
<div class="container my-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap mb-3 gap-3">
    <div>
      <h1 class="mb-1"><i class="bi bi-activity me-2"></i>SDCC ONWv3 稼働状況ポータル</h1>
      <div class="last-updated">
        <i class="bi bi-clock-history me-1"></i>
        最終更新: <span id="lastUpdated"><%= lastUpdatedAt %></span>
      </div>
    </div>

    <div class="d-flex align-items-center gap-2">
      <label for="refreshInterval" class="small mb-0">自動更新</label>
      <select id="refreshInterval" class="form-select form-select-sm w-auto">
        <option value="0">しない</option>
        <option value="10000">10秒</option>
        <option value="30000">30秒</option>
        <option value="60000">1分</option>
        <option value="300000" selected>5分</option>
        <option value="1800000">30分</option>
      </select>
      <button id="manualRefresh" class="btn btn-outline-primary btn-sm" title="今すぐ更新"><i class="bi bi-arrow-clockwise"></i></button>
      <button id="themeToggle" class="btn btn-outline-secondary btn-sm" title="ダークモード切替"><i class="bi bi-moon-fill"></i></button>
    </div>
  </div>

  <div class="search-toolbar mb-3">
    <div class="search-input-wrap">
      <input id="searchInput" type="text" class="form-control" placeholder="キーワードで検索（案件名・カテゴリ・タグなど）" value="<%= filters.q %>">
    </div>
    <label for="pageSizeSelect" class="small mb-0">表示件数</label>
    <select id="pageSizeSelect" class="form-select form-select-sm w-auto">
      <% pageSizeOptions.forEach((size) => { %>
        <option value="<%= size %>" <%= filters.pageSize === size ? 'selected' : '' %>><%= size %></option>
      <% }) %>
    </select>
    <button id="applyFiltersBtn" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>検索</button>
    <button
      id="desktopFilterToggle"
      class="btn btn-outline-secondary btn-sm"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#desktopFilterCollapse"
      aria-expanded="false"
      aria-controls="desktopFilterCollapse"
    >
      <i class="bi bi-funnel me-1"></i>フィルタを開く
    </button>
    <button id="clearFilters" class="btn btn-outline-danger btn-sm"><i class="bi bi-x-circle me-1"></i>フィルタ解除</button>
  </div>

  <div id="activeFilters" class="d-flex flex-wrap gap-2 mb-3">
    <% activeFilterChips.forEach((chip) => { %>
      <button class="btn btn-sm btn-outline-secondary rounded-pill filter-chip" data-type="<%= chip.type %>" data-value="<%= chip.value %>">
        <%= chip.label %> <i class="bi bi-x ms-1"></i>
      </button>
    <% }) %>
  </div>

  <div class="desktop-filter-panel mb-3">
    <div class="collapse" id="desktopFilterCollapse">
      <div class="p-3 border rounded-4">
        <div class="fw-semibold mb-2"><i class="bi bi-funnel me-1"></i>詳細フィルタ</div>
        <div class="d-flex flex-wrap gap-3">
          <select id="statusFilter" class="form-select" multiple size="4" style="min-width:180px;">
            <% statuses.forEach((s) => { %>
              <option value="<%= s.name %>" <%= filters.statuses.includes(s.name) ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
          </select>
          <select id="categoryFilter" class="form-select" multiple size="4" style="min-width:180px;">
            <% categories.forEach((c) => { %>
              <option value="<%= c.name %>" <%= filters.categories.includes(c.name) ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
          <select id="tagFilter" class="form-select" multiple size="4" style="min-width:180px;">
            <% tags.forEach((t) => { %>
              <option value="<%= t.name %>" <%= filters.tags.includes(t.name) ? 'selected' : '' %>><%= t.name %></option>
            <% }) %>
          </select>
        </div>
      </div>
    </div>
  </div>

  <div class="mobile-filter-panel mb-3">
    <div class="accordion" id="filterAccordion">
      <div class="accordion-item">
        <h2 class="accordion-header" id="filterHeading">
          <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#filterCollapse" aria-expanded="false" aria-controls="filterCollapse">
            <i class="bi bi-funnel me-2"></i>詳細フィルタ
          </button>
        </h2>
        <div id="filterCollapse" class="accordion-collapse collapse" aria-labelledby="filterHeading" data-bs-parent="#filterAccordion">
          <div class="accordion-body d-flex flex-wrap gap-2">
            <select id="statusFilterMobile" class="form-select" multiple size="4">
              <% statuses.forEach((s) => { %>
                <option value="<%= s.name %>" <%= filters.statuses.includes(s.name) ? 'selected' : '' %>><%= s.name %></option>
              <% }) %>
            </select>
            <select id="categoryFilterMobile" class="form-select" multiple size="4">
              <% categories.forEach((c) => { %>
                <option value="<%= c.name %>" <%= filters.categories.includes(c.name) ? 'selected' : '' %>><%= c.name %></option>
              <% }) %>
            </select>
            <select id="tagFilterMobile" class="form-select" multiple size="4">
              <% tags.forEach((t) => { %>
                <option value="<%= t.name %>" <%= filters.tags.includes(t.name) ? 'selected' : '' %>><%= t.name %></option>
              <% }) %>
            </select>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="content-area">
  <ul class="nav nav-tabs mb-4" id="statusTabs">
    <li class="nav-item"><a class="nav-link <%= filters.tab === 'incidents' ? 'active' : '' %>" href="#" data-tab="incidents"><i class="bi bi-exclamation-circle me-1"></i>障害情報</a></li>
    <li class="nav-item"><a class="nav-link <%= filters.tab === 'maintenance' ? 'active' : '' %>" href="#" data-tab="maintenance"><i class="bi bi-tools me-1"></i>メンテナンス情報</a></li>
  </ul>

  <div id="tab-incidents" class="tab-content <%= filters.tab === 'incidents' ? 'active' : '' %>">
    <% if (incidents.length === 0) { %>
      <div class="alert alert-secondary text-center">条件に一致する障害情報はありません。</div>
    <% } %>
    <% incidents.forEach((incident) => { %>
      <div class="incident-card">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h4 class="mb-0"><i class="bi bi-exclamation-circle me-2 text-danger"></i><%= incident.title %></h4>
          <span class="badge status-badge" style="background-color:<%= incident.status_color %>;color:<%= incident.status_text_color %>"><%= incident.status %></span>
        </div>
        <div class="meta-item mb-2">
          管理番号: <strong><%= incident.code %></strong> | 分類: <%= incident.category %> | 発生: <%= incident.start_at_fmt %><% if (incident.end_at_fmt) { %> | 復旧: <%= incident.end_at_fmt %><% } %>
        </div>
        <div class="mb-2">
          <% incident.tags.forEach((tag) => { %><span class="badge bg-secondary me-1"><%= tag %></span><% }) %>
        </div>
        <div class="truncate"><%- incident.info_html %></div>
        <button
          class="btn btn-sm btn-outline-primary mt-2 detail-btn"
          data-title="<%= incident.title %>"
          data-html="<%= incident.info_html %>"
          data-meta="管理番号: <%= incident.code %> / 分類: <%= incident.category %>"
        >詳細を表示</button>
      </div>
    <% }) %>

    <div class="d-flex justify-content-between align-items-center mt-3">
      <div class="pager-summary">全 <%= pagination.incidents.totalCount %> 件 / <%= pagination.incidents.page %> / <%= pagination.incidents.totalPages %> ページ</div>
      <div class="btn-group">
        <a class="btn btn-sm btn-outline-secondary <%= pagination.incidents.page <= 1 ? 'disabled' : '' %>" href="<%= queryFor({ tab: 'incidents', incPage: Math.max(1, pagination.incidents.page - 1) }) %>">前へ</a>
        <a class="btn btn-sm btn-outline-secondary <%= pagination.incidents.page >= pagination.incidents.totalPages ? 'disabled' : '' %>" href="<%= queryFor({ tab: 'incidents', incPage: Math.min(pagination.incidents.totalPages, pagination.incidents.page + 1) }) %>">次へ</a>
      </div>
    </div>
  </div>

  <div id="tab-maintenance" class="tab-content <%= filters.tab === 'maintenance' ? 'active' : '' %>">
    <% if (maintenance.length === 0) { %>
      <div class="alert alert-secondary text-center">条件に一致するメンテナンス情報はありません。</div>
    <% } %>
    <% maintenance.forEach((item) => { %>
      <div class="maint-card">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h4 class="mb-0"><i class="bi bi-tools me-2 text-info"></i><%= item.title %></h4>
          <span class="badge status-badge" style="background-color:<%= item.status_color %>;color:<%= item.status_text_color %>"><%= item.status %></span>
        </div>
        <div class="meta-item mb-2">
          管理番号: <strong><%= item.code || ('MTN-ID-' + item.id) %></strong> | 分類: <%= item.category %> | 期間: <%= item.start_time_fmt %> ～ <%= item.end_time_fmt || '未定' %>
        </div>
        <div class="mb-2">
          <% item.tags.forEach((tag) => { %><span class="badge bg-secondary me-1"><%= tag %></span><% }) %>
        </div>
        <div class="truncate"><%- item.info_html %></div>
        <button
          class="btn btn-sm btn-outline-primary mt-2 detail-btn"
          data-title="<%= item.title %>"
          data-html="<%= item.info_html %>"
          data-meta="管理番号: <%= item.code || ('MTN-ID-' + item.id) %> / 分類: <%= item.category %>"
        >詳細を表示</button>
      </div>
    <% }) %>

    <div class="d-flex justify-content-between align-items-center mt-3">
      <div class="pager-summary">全 <%= pagination.maintenance.totalCount %> 件 / <%= pagination.maintenance.page %> / <%= pagination.maintenance.totalPages %> ページ</div>
      <div class="btn-group">
        <a class="btn btn-sm btn-outline-secondary <%= pagination.maintenance.page <= 1 ? 'disabled' : '' %>" href="<%= queryFor({ tab: 'maintenance', mtPage: Math.max(1, pagination.maintenance.page - 1) }) %>">前へ</a>
        <a class="btn btn-sm btn-outline-secondary <%= pagination.maintenance.page >= pagination.maintenance.totalPages ? 'disabled' : '' %>" href="<%= queryFor({ tab: 'maintenance', mtPage: Math.min(pagination.maintenance.totalPages, pagination.maintenance.page + 1) }) %>">次へ</a>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="detailModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="modalTitle"></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="modalMeta" class="small text-muted mb-2"></div>
        <div id="modalBody"></div>
      </div>
    </div>
  </div>
</div>

<div id="toastContainer" class="position-fixed bottom-0 end-0 p-3" style="z-index: 1100;"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
let refreshTimer = null;
let activeTab = '<%= filters.tab %>';

const htmlEl = document.documentElement;
const themeToggleBtn = document.getElementById('themeToggle');
function setTheme(theme){
  htmlEl.setAttribute('data-bs-theme', theme);
  localStorage.setItem('theme', theme);
  themeToggleBtn.innerHTML = theme === 'dark' ? '<i class="bi bi-sun-fill"></i>' : '<i class="bi bi-moon-fill"></i>';
}
themeToggleBtn.addEventListener('click', () => setTheme(htmlEl.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark'));
setTheme(localStorage.getItem('theme') || 'light');

function showToast(message, type='success', withRetry=false){
  const container = document.getElementById('toastContainer');
  const toastEl = document.createElement('div');
  toastEl.className = `toast align-items-center text-bg-${type} border-0`;
  const retryHtml = withRetry ? '<button type="button" class="btn btn-sm btn-light ms-2 retry-refresh">再試行</button>' : '';
  toastEl.innerHTML = `<div class="d-flex"><div class="toast-body">${message}${retryHtml}</div><button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button></div>`;
  container.appendChild(toastEl);
  const toast = new bootstrap.Toast(toastEl, { delay: withRetry ? 6000 : 2500 });
  toast.show();
  const retryBtn = toastEl.querySelector('.retry-refresh');
  if (retryBtn) retryBtn.addEventListener('click', () => fetchLatestData(true));
  toastEl.addEventListener('hidden.bs.toast', () => toastEl.remove());
}

function selectedValues(id){
  const el = document.getElementById(id);
  if (!el) return [];
  return Array.from(el.selectedOptions).map((o) => o.value);
}

function setSelectedValues(id, values){
  const el = document.getElementById(id);
  if (!el) return;
  Array.from(el.options).forEach((opt) => {
    opt.selected = values.includes(opt.value);
  });
}

function syncDesktopAndMobile(source){
  const pairs = {
    statusFilter: 'statusFilterMobile',
    categoryFilter: 'categoryFilterMobile',
    tagFilter: 'tagFilterMobile',
  };
  Object.entries(pairs).forEach(([desktop, mobile]) => {
    const from = source === 'mobile' ? mobile : desktop;
    const to = source === 'mobile' ? desktop : mobile;
    setSelectedValues(to, selectedValues(from));
  });
}

function setActiveTab(tab){
  activeTab = tab;
  document.querySelectorAll('.nav-link').forEach((el) => el.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach((el) => el.classList.remove('active'));
  document.querySelector(`[data-tab="${tab}"]`)?.classList.add('active');
  document.getElementById(`tab-${tab}`)?.classList.add('active');
}

function buildSearchParams() {
  const params = new URLSearchParams();
  const q = document.getElementById('searchInput').value.trim();
  if (q) params.set('q', q);
  selectedValues('statusFilter').forEach((v) => params.append('statuses', v));
  selectedValues('categoryFilter').forEach((v) => params.append('categories', v));
  selectedValues('tagFilter').forEach((v) => params.append('tags', v));
  params.set('tab', activeTab);
  params.set('inc_page', '1');
  params.set('mt_page', '1');
  params.set('page_size', document.getElementById('pageSizeSelect').value);
  return params;
}

function navigateWithCurrentFilters() {
  window.location.href = `/?${buildSearchParams().toString()}`;
}

document.getElementById('applyFiltersBtn').addEventListener('click', () => {
  syncDesktopAndMobile('desktop');
  navigateWithCurrentFilters();
});

document.getElementById('searchInput').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    e.preventDefault();
    syncDesktopAndMobile('desktop');
    navigateWithCurrentFilters();
  }
});

document.getElementById('pageSizeSelect').addEventListener('change', () => {
  syncDesktopAndMobile('desktop');
  navigateWithCurrentFilters();
});

['statusFilterMobile', 'categoryFilterMobile', 'tagFilterMobile'].forEach((id) => {
  const el = document.getElementById(id);
  if (!el) return;
  el.addEventListener('change', () => syncDesktopAndMobile('mobile'));
});

document.getElementById('clearFilters').addEventListener('click', () => {
  const params = new URLSearchParams();
  params.set('tab', activeTab);
  params.set('inc_page', '1');
  params.set('mt_page', '1');
  params.set('page_size', document.getElementById('pageSizeSelect').value);
  window.location.href = `/?${params.toString()}`;
});

document.getElementById('activeFilters').addEventListener('click', (e) => {
  const chip = e.target.closest('.filter-chip');
  if (!chip) return;

  if (chip.dataset.type === 'q') {
    document.getElementById('searchInput').value = '';
  }
  if (chip.dataset.type === 'statuses') {
    ['statusFilter', 'statusFilterMobile'].forEach((id) => {
      const values = selectedValues(id).filter((v) => v !== chip.dataset.value);
      setSelectedValues(id, values);
    });
  }
  if (chip.dataset.type === 'categories') {
    ['categoryFilter', 'categoryFilterMobile'].forEach((id) => {
      const values = selectedValues(id).filter((v) => v !== chip.dataset.value);
      setSelectedValues(id, values);
    });
  }
  if (chip.dataset.type === 'tags') {
    ['tagFilter', 'tagFilterMobile'].forEach((id) => {
      const values = selectedValues(id).filter((v) => v !== chip.dataset.value);
      setSelectedValues(id, values);
    });
  }
  syncDesktopAndMobile('desktop');
  navigateWithCurrentFilters();
});

const desktopFilterCollapse = document.getElementById('desktopFilterCollapse');
const desktopFilterToggle = document.getElementById('desktopFilterToggle');
function syncDesktopFilterToggleLabel() {
  if (!desktopFilterCollapse || !desktopFilterToggle) return;
  const isOpen = desktopFilterCollapse.classList.contains('show');
  if (isOpen) {
    desktopFilterToggle.innerHTML = '<i class="bi bi-x-circle me-1"></i>フィルタを隠す';
    desktopFilterToggle.classList.remove('btn-outline-secondary');
    desktopFilterToggle.classList.add('btn-secondary');
  } else {
    desktopFilterToggle.innerHTML = '<i class="bi bi-funnel me-1"></i>フィルタを開く';
    desktopFilterToggle.classList.remove('btn-secondary');
    desktopFilterToggle.classList.add('btn-outline-secondary');
  }
}
if (desktopFilterCollapse && desktopFilterToggle) {
  desktopFilterCollapse.addEventListener('shown.bs.collapse', syncDesktopFilterToggleLabel);
  desktopFilterCollapse.addEventListener('hidden.bs.collapse', syncDesktopFilterToggleLabel);
  desktopFilterToggle.addEventListener('click', () => setTimeout(syncDesktopFilterToggleLabel, 0));
}

document.querySelectorAll('[data-tab]').forEach((tab) => {
  tab.addEventListener('click', (e) => {
    e.preventDefault();
    setActiveTab(tab.dataset.tab);
  });
});

function showDetails(title, html, meta){
  document.getElementById('modalTitle').innerText = title;
  document.getElementById('modalMeta').innerText = meta || '';
  document.getElementById('modalBody').innerHTML = html;
  new bootstrap.Modal(document.getElementById('detailModal')).show();
}

document.addEventListener('click', (e) => {
  const button = e.target.closest('.detail-btn');
  if (!button) return;
  showDetails(button.dataset.title || '', button.dataset.html || '', button.dataset.meta || '');
});

function setAutoRefresh() {
  const interval = parseInt(document.getElementById('refreshInterval').value, 10);
  if (refreshTimer) clearInterval(refreshTimer);
  if (interval > 0) refreshTimer = setInterval(fetchLatestData, interval);
}
document.getElementById('refreshInterval').addEventListener('change', setAutoRefresh);
document.getElementById('manualRefresh').addEventListener('click', () => fetchLatestData(true));

async function fetchLatestData(manual = false) {
  try {
    const res = await fetch(window.location.href, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const html = await res.text();
    const doc = new DOMParser().parseFromString(html, 'text/html');
    document.getElementById('tab-incidents').innerHTML = doc.getElementById('tab-incidents').innerHTML;
    document.getElementById('tab-maintenance').innerHTML = doc.getElementById('tab-maintenance').innerHTML;
    document.getElementById('lastUpdated').innerText = doc.getElementById('lastUpdated').innerText;
    setActiveTab(activeTab);
    const t = new Date().toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' });
    showToast(manual ? `最新データを取得しました（${t}）` : `自動更新完了（${t}）`, 'success');
  } catch (e) {
    console.error(e);
    showToast('データ更新に失敗しました。', 'danger', true);
  }
}

window.addEventListener('DOMContentLoaded', () => {
  const hash = window.location.hash;
  if (hash === '#maintenance') setActiveTab('maintenance');
  else setActiveTab(activeTab);
  setAutoRefresh();
  syncDesktopFilterToggleLabel();
});
</script>
</body>
</html>
