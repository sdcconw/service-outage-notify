<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <title>メンテナンス管理</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <style>
    body { padding-top: 70px; }
    .required-label::after { content: '必須'; color: #fff; background:#dc3545; border-radius: .25rem; font-size: .7rem; padding: .05rem .35rem; margin-left: .4rem; }
    .optional-label::after { content: '任意'; color: #495057; background:#e9ecef; border-radius: .25rem; font-size: .7rem; padding: .05rem .35rem; margin-left: .4rem; }
  </style>
</head>
<body>

<nav class="navbar fixed-top navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container-fluid">
    <a class="navbar-brand" href="#">管理画面</a>
    <div class="collapse navbar-collapse">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/admin/incidents">障害一覧</a></li>
        <li class="nav-item"><a class="nav-link active" href="/admin/maintenance">メンテナンス一覧</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/settings">設定管理</a></li>
        <li class="nav-item"><a class="nav-link" href="/">お知らせページ</a></li>
      </ul>
    </div>
  </div>
</nav>

<div class="container my-4">
  <h2>新規登録 / 編集</h2>
  <form id="maintenanceForm" method="POST" action="/admin/maintenance/add<%= listState.queryString %>" class="needs-validation" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <input type="hidden" name="id" id="maintenanceId" />
    <div id="editNotice" class="alert alert-warning d-none">
      編集中: <span id="editingTitle"></span>
      <button type="button" class="btn btn-sm btn-secondary ms-3" onclick="cancelEdit()">キャンセル</button>
    </div>

    <div class="mb-3">
      <label class="form-label required-label" for="titleInput">メンテナンスタイトル</label>
      <input id="titleInput" type="text" name="title" class="form-control" required />
      <div class="invalid-feedback">タイトルを入力してください。</div>
    </div>

    <div class="mb-3">
      <label class="form-label required-label" for="categorySelect">カテゴリ</label>
      <select id="categorySelect" name="category_id" class="form-select" required>
        <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>"><%= cat.name %></option>
        <% }) %>
      </select>
      <div class="invalid-feedback">カテゴリを選択してください。</div>
    </div>

    <div class="mb-3">
      <label class="form-label required-label" for="statusSelect">ステータス</label>
      <select id="statusSelect" name="status_id" class="form-select" required>
        <% statuses.forEach(stat => { %>
          <option value="<%= stat.id %>"><%= stat.name %></option>
        <% }) %>
      </select>
      <div class="invalid-feedback">ステータスを選択してください。</div>
    </div>

    <div class="mb-3">
      <label class="form-label optional-label" for="descriptionTextarea">内容（Markdown）</label>
      <textarea id="descriptionTextarea" name="description" class="form-control" rows="4" oninput="updatePreview(this.value)"></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label required-label" for="startTimeInput">開始日時</label>
      <input id="startTimeInput" type="datetime-local" name="start_time" class="form-control" required />
      <div class="invalid-feedback">開始日時を入力してください。</div>
    </div>

    <div class="mb-3">
      <label class="form-label optional-label" for="endTimeInput">終了日時</label>
      <input id="endTimeInput" type="datetime-local" name="end_time" class="form-control" />
    </div>

    <div class="mb-3">
      <label class="form-label">プレビュー</label>
      <div id="preview" class="p-2 border bg-light"></div>
    </div>

    <div class="mb-3">
      <label class="form-label optional-label" for="tagsSelect">タグ</label>
      <select id="tagsSelect" name="tags" class="form-select" multiple>
        <% tags.forEach(tag => { %>
          <option value="<%= tag.id %>"><%= tag.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="d-flex align-items-center gap-3">
      <button type="submit" class="btn btn-primary">保存</button>
      <div class="form-check mb-0">
        <input class="form-check-input" type="checkbox" id="discordNotify" name="discord_notify" value="1" />
        <label class="form-check-label" for="discordNotify">Discordに送信</label>
      </div>
    </div>
  </form>

  <hr />

  <div class="d-flex justify-content-between align-items-center mb-2">
    <h2 class="mb-0">メンテナンス一覧</h2>
    <div class="d-flex align-items-center gap-2">
      <label for="pageSizeSelect" class="small mb-0">表示件数</label>
      <select id="pageSizeSelect" class="form-select form-select-sm w-auto">
        <% [10,20,50,100].forEach(size => { %>
          <option value="<%= size %>" <%= listState.pageSize === size ? 'selected' : '' %>><%= size %></option>
        <% }) %>
      </select>
    </div>
  </div>

  <table class="table table-bordered table-hover" id="maintenanceTable">
    <thead>
      <tr>
        <th><a href="#" class="sort-link" data-sort="code">管理番号</a></th>
        <th><a href="#" class="sort-link" data-sort="category">カテゴリ</a></th>
        <th><a href="#" class="sort-link" data-sort="title">タイトル</a></th>
        <th><a href="#" class="sort-link" data-sort="status">ステータス</a></th>
        <th>タグ</th>
        <th><a href="#" class="sort-link" data-sort="start_time">期間</a></th>
        <th>内容</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% maintenances.forEach(item => { %>
        <tr class="<%= item.is_hidden ? 'table-secondary' : '' %>">
          <td><%= item.code || ('MTN-ID-' + item.id) %></td>
          <td><%= item.category %></td>
          <td><%= item.title %></td>
          <td><span class="badge" style="background-color:<%= item.status_color %>;color:<%= item.status_text_color %>;"><%= item.status %></span></td>
          <td>
            <% item.tags.forEach(tag => { %><span class="badge bg-secondary me-1"><%= tag %></span><% }) %>
          </td>
          <td><%= item.start_time_fmt %> ～ <%= item.end_time_fmt || '未定' %></td>
          <td><div><%= (item.description || '').slice(0, 200) %></div></td>
          <td>
            <button
              class="btn btn-sm btn-outline-primary"
              onclick="editMaintenanceFromData(this)"
              data-maintenance-id="<%= item.id %>"
              data-maintenance-title="<%= item.title %>"
              data-maintenance-category="<%= item.category_id %>"
              data-maintenance-status="<%= item.status_id %>"
              data-maintenance-description="<%= (item.description || '').replace(/\"/g, '&quot;') %>"
              data-maintenance-start="<%= item.start_time %>"
              data-maintenance-end="<%= item.end_time || '' %>"
              data-maintenance-tags="<%= (item.tag_ids || []).join(',') %>"
            >編集</button>
            <form method="POST" action="/admin/maintenance/hide/<%= item.id %><%= listState.queryString %>" class="d-inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn btn-sm btn-outline-warning"><%= item.is_hidden ? '表示' : '非表示' %></button>
            </form>
            <form method="POST" action="/admin/maintenance/delete/<%= item.id %><%= listState.queryString %>" class="d-inline" onsubmit="return confirm('削除してもよろしいですか？');">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button class="btn btn-sm btn-outline-danger">削除</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="d-flex justify-content-between align-items-center mt-3">
    <div class="small text-muted">全 <%= listState.totalCount %> 件 / <%= listState.page %> / <%= listState.totalPages %> ページ</div>
    <div class="btn-group">
      <a class="btn btn-sm btn-outline-secondary <%= listState.page <= 1 ? 'disabled' : '' %>" href="?page=<%= Math.max(1, listState.page - 1) %>&page_size=<%= listState.pageSize %>&sort=<%= listState.sort %>&order=<%= listState.order %>">前へ</a>
      <a class="btn btn-sm btn-outline-secondary <%= listState.page >= listState.totalPages ? 'disabled' : '' %>" href="?page=<%= Math.min(listState.totalPages, listState.page + 1) %>&page_size=<%= listState.pageSize %>&sort=<%= listState.sort %>&order=<%= listState.order %>">次へ</a>
    </div>
  </div>
</div>

<script>
const listState = {
  page: <%= listState.page %>,
  pageSize: <%= listState.pageSize %>,
  sort: '<%= listState.sort %>',
  order: '<%= listState.order %>',
};
const listQueryString = '<%= listState.queryString %>';

function makeListQuery(next = {}) {
  const params = new URLSearchParams({
    page: String(next.page ?? listState.page),
    page_size: String(next.pageSize ?? listState.pageSize),
    sort: String(next.sort ?? listState.sort),
    order: String(next.order ?? listState.order),
  });
  return `?${params.toString()}`;
}

const updatePreview = md => {
  try {
    document.getElementById('preview').innerHTML = marked.parse(md || '');
  } catch {
    document.getElementById('preview').innerHTML = '<div class="text-danger">プレビューエラー</div>';
  }
};

const editMaintenanceFromData = button => {
  const maintenance = {
    id: button.dataset.maintenanceId,
    title: button.dataset.maintenanceTitle,
    category_id: button.dataset.maintenanceCategory,
    status_id: button.dataset.maintenanceStatus,
    description: button.dataset.maintenanceDescription.replace(/&quot;/g, '"').replace(/\\n/g, '\n'),
    start_time: button.dataset.maintenanceStart,
    end_time: button.dataset.maintenanceEnd,
    tag_ids: button.dataset.maintenanceTags ? button.dataset.maintenanceTags.split(',').map(v => v.trim()).filter(Boolean) : []
  };

  document.getElementById('maintenanceId').value = maintenance.id;
  document.getElementById('titleInput').value = maintenance.title;
  document.getElementById('categorySelect').value = String(maintenance.category_id);
  document.getElementById('statusSelect').value = String(maintenance.status_id);
  document.getElementById('descriptionTextarea').value = maintenance.description || '';
  document.getElementById('startTimeInput').value = maintenance.start_time ? maintenance.start_time.slice(0,16) : '';
  document.getElementById('endTimeInput').value = maintenance.end_time ? maintenance.end_time.slice(0,16) : '';

  const tagSelect = document.getElementById('tagsSelect');
  const tagIds = maintenance.tag_ids.map(String);
  Array.from(tagSelect.options).forEach(option => {
    option.selected = tagIds.includes(option.value);
  });

  updatePreview(maintenance.description || '');

  const form = document.getElementById('maintenanceForm');
  form.action = `/admin/maintenance/edit/${maintenance.id}${listQueryString}`;

  document.getElementById('editNotice').classList.remove('d-none');
  document.getElementById('editingTitle').innerText = maintenance.title || '';
  document.getElementById('discordNotify').checked = false;
};

const cancelEdit = () => {
  const form = document.getElementById('maintenanceForm');
  form.reset();
  form.action = `/admin/maintenance/add${listQueryString}`;
  document.getElementById('maintenanceId').value = '';
  document.getElementById('preview').innerHTML = '';
  document.getElementById('editNotice').classList.add('d-none');
  document.getElementById('discordNotify').checked = false;
  form.classList.remove('was-validated');
};

document.getElementById('maintenanceForm').addEventListener('submit', (e) => {
  const form = e.currentTarget;
  if (!form.checkValidity()) {
    e.preventDefault();
    e.stopPropagation();
  }
  form.classList.add('was-validated');
});

document.querySelectorAll('.sort-link').forEach(link => {
  link.addEventListener('click', (e) => {
    e.preventDefault();
    const sort = link.dataset.sort;
    const order = (listState.sort === sort && listState.order === 'asc') ? 'desc' : 'asc';
    window.location.href = makeListQuery({ page: 1, sort, order });
  });
});

document.getElementById('pageSizeSelect').addEventListener('change', (e) => {
  const pageSize = Number(e.target.value);
  window.location.href = makeListQuery({ page: 1, pageSize });
});
</script>

</body>
</html>
