<%# Admin master-settings template (categories/statuses/tags). Comments are hidden via EJS syntax. %>
<!DOCTYPE html>
<html>
<head>
  <title>設定管理</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { padding-top: 70px; }
    .required-label::after { content: '必須'; color: #fff; background:#dc3545; border-radius: .25rem; font-size: .7rem; padding: .05rem .35rem; margin-left: .4rem; }
    .optional-label::after { content: '任意'; color: #495057; background:#e9ecef; border-radius: .25rem; font-size: .7rem; padding: .05rem .35rem; margin-left: .4rem; }
  </style>
</head>
<body>

<nav class="navbar fixed-top navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container-fluid">
    <a class="navbar-brand" href="#">管理画面</a>
    <div class="collapse navbar-collapse">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/admin/incidents">障害一覧</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/maintenance">メンテナンス一覧</a></li>
        <li class="nav-item"><a class="nav-link active" href="/admin/settings">設定管理</a></li>
        <li class="nav-item"><a class="nav-link" href="/">お知らせページ</a></li>
      </ul>
    </div>
  </div>
</nav>

<div class="container my-4">
  <h2>カテゴリ設定</h2>
  <form id="categoryForm" method="POST" action="/admin/settings/add/category" class="mb-3 needs-validation" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="id" id="categoryId">
    <div class="mb-2">
      <label class="required-label" for="categoryName">カテゴリ名</label>
      <input type="text" name="name" id="categoryName" class="form-control" required>
      <div class="invalid-feedback">カテゴリ名を入力してください。</div>
    </div>
    <div id="categoryEditNotice" class="alert alert-warning d-none">
      編集中カテゴリID: <span id="categoryEditId"></span>
      <button type="button" class="btn btn-sm btn-secondary ms-3" onclick="cancelCategoryEdit()">キャンセル</button>
    </div>
    <button type="submit" class="btn btn-primary">保存</button>
  </form>

  <table class="table">
    <thead><tr><th>ID</th><th>名前</th><th>操作</th></tr></thead>
    <tbody>
      <% categories.forEach(cat => { %>
        <tr>
          <td><%= cat.id %></td>
          <td><%= cat.name %></td>
          <td>
            <button class="btn btn-sm btn-outline-primary" onclick='editCategory(<%= cat.id %>, <%- JSON.stringify(cat.name || "") %>)'>編集</button>
            <form method="POST" action="/admin/settings/delete/category/<%= cat.id %>" class="d-inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-sm btn-outline-danger">削除</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <hr>

  <h2>ステータス設定</h2>
  <form id="statusForm" method="POST" action="/admin/settings/add/status" class="mb-3 needs-validation" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="id" id="statusId">
    <div class="mb-2">
      <label class="required-label" for="statusName">ステータス名</label>
      <input type="text" name="name" id="statusName" class="form-control" required>
      <div class="invalid-feedback">ステータス名を入力してください。</div>
    </div>
    <div class="mb-2">
      <label class="optional-label" for="statusColor">表示色</label>
      <select name="color" id="statusColor" class="form-select">
        <% bootstrapColors.forEach(colorKey => { %>
          <option value="<%= colorKey %>" <%= colorKey === 'secondary' ? 'selected' : '' %>><%= colorKey %></option>
        <% }) %>
      </select>
    </div>
    <div id="statusEditNotice" class="alert alert-warning d-none">
      編集中ステータスID: <span id="statusEditId"></span>
      <button type="button" class="btn btn-sm btn-secondary ms-3" onclick="cancelStatusEdit()">キャンセル</button>
    </div>
    <button type="submit" class="btn btn-primary">保存</button>
  </form>

  <table class="table">
    <thead><tr><th>ID</th><th>名前</th><th>色</th><th>操作</th></tr></thead>
    <tbody>
      <% statuses.forEach(stat => { %>
        <tr>
          <td><%= stat.id %></td>
          <td><%= stat.name %></td>
          <td><span class="badge" style="background-color:<%= stat.color_resolved.hex %>;color:<%= stat.color_resolved.textColor %>;"><%= stat.color_resolved.key || stat.color %></span></td>
          <td>
            <button class="btn btn-sm btn-outline-primary" onclick='editStatus(<%= stat.id %>, <%- JSON.stringify(stat.name || "") %>, <%- JSON.stringify(stat.color_resolved.key || "secondary") %>)'>編集</button>
            <form method="POST" action="/admin/settings/delete/status/<%= stat.id %>" class="d-inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-sm btn-outline-danger">削除</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <hr>

  <h2>タグ設定</h2>
  <form id="tagForm" method="POST" action="/admin/settings/add/tag" class="mb-3 needs-validation" novalidate>
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="id" id="tagId">
    <div class="mb-2">
      <label class="required-label" for="tagName">タグ名</label>
      <input type="text" name="name" id="tagName" class="form-control" required>
      <div class="invalid-feedback">タグ名を入力してください。</div>
    </div>
    <div id="tagEditNotice" class="alert alert-warning d-none">
      編集中タグID: <span id="tagEditId"></span>
      <button type="button" class="btn btn-sm btn-secondary ms-3" onclick="cancelTagEdit()">キャンセル</button>
    </div>
    <button type="submit" class="btn btn-primary">保存</button>
  </form>

  <table class="table">
    <thead><tr><th>ID</th><th>名前</th><th>操作</th></tr></thead>
    <tbody>
      <% tags.forEach(tag => { %>
        <tr>
          <td><%= tag.id %></td>
          <td><%= tag.name %></td>
          <td>
            <button class="btn btn-sm btn-outline-primary" onclick='editTag(<%= tag.id %>, <%- JSON.stringify(tag.name || "") %>)'>編集</button>
            <form method="POST" action="/admin/settings/delete/tag/<%= tag.id %>" class="d-inline">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-sm btn-outline-danger">削除</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
function applyValidation(formId) {
  document.getElementById(formId).addEventListener('submit', (e) => {
    const form = e.currentTarget;
    if (!form.checkValidity()) {
      e.preventDefault();
      e.stopPropagation();
    }
    form.classList.add('was-validated');
  });
}

applyValidation('categoryForm');
applyValidation('statusForm');
applyValidation('tagForm');

function editCategory(id, name) {
  document.getElementById('categoryId').value = id;
  document.getElementById('categoryName').value = name;
  document.getElementById('categoryForm').action = `/admin/settings/edit/category/${id}`;
  document.getElementById('categoryEditNotice').classList.remove('d-none');
  document.getElementById('categoryEditId').innerText = id;
}
function cancelCategoryEdit() {
  document.getElementById('categoryId').value = '';
  document.getElementById('categoryName').value = '';
  document.getElementById('categoryForm').action = `/admin/settings/add/category`;
  document.getElementById('categoryEditNotice').classList.add('d-none');
  document.getElementById('categoryForm').classList.remove('was-validated');
}

function editStatus(id, name, color) {
  document.getElementById('statusId').value = id;
  document.getElementById('statusName').value = name;
  document.getElementById('statusColor').value = color || 'secondary';
  document.getElementById('statusForm').action = `/admin/settings/edit/status/${id}`;
  document.getElementById('statusEditNotice').classList.remove('d-none');
  document.getElementById('statusEditId').innerText = id;
}
function cancelStatusEdit() {
  document.getElementById('statusId').value = '';
  document.getElementById('statusName').value = '';
  document.getElementById('statusColor').value = 'secondary';
  document.getElementById('statusForm').action = `/admin/settings/add/status`;
  document.getElementById('statusEditNotice').classList.add('d-none');
  document.getElementById('statusForm').classList.remove('was-validated');
}

function editTag(id, name) {
  document.getElementById('tagId').value = id;
  document.getElementById('tagName').value = name;
  document.getElementById('tagForm').action = `/admin/settings/edit/tag/${id}`;
  document.getElementById('tagEditNotice').classList.remove('d-none');
  document.getElementById('tagEditId').innerText = id;
}
function cancelTagEdit() {
  document.getElementById('tagId').value = '';
  document.getElementById('tagName').value = '';
  document.getElementById('tagForm').action = `/admin/settings/add/tag`;
  document.getElementById('tagEditNotice').classList.add('d-none');
  document.getElementById('tagForm').classList.remove('was-validated');
}
</script>

</body>
</html>
