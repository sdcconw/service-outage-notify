<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <title>障害管理</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <style>
    body { padding-top: 70px; }
    th.sortable { cursor: pointer; user-select: none; }
    th.sortable span { margin-left: 6px; color: #666; }
  </style>
</head>
<body>

<nav class="navbar fixed-top navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container-fluid">
    <a class="navbar-brand" href="#">管理画面</a>
    <div class="collapse navbar-collapse">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/admin/incidents">障害一覧</a></li>
        <li class="nav-item"><a class="nav-link" href="/admin/settings">設定管理</a></li>
        <li class="nav-item"><a class="nav-link" href="/">お知らせページ</a></li>
      </ul>
    </div>
  </div>
</nav>

<div class="container my-4">
  <h2>新規登録 / 編集</h2>
  <form id="incidentForm" method="POST" action="/admin/incidents/add">
    <input type="hidden" name="id" id="incidentId" />
    <div id="editNotice" class="alert alert-warning d-none">
      編集中: <span id="editingCode"></span>
      <button type="button" class="btn btn-sm btn-secondary ms-3" onclick="cancelEdit()">キャンセル</button>
    </div>

    <div class="mb-3">
      <label class="form-label" for="titleInput">案件名</label>
      <input id="titleInput" type="text" name="title" class="form-control" required />
    </div>
    <div class="mb-3">
      <label class="form-label" for="categorySelect">カテゴリ</label>
      <select id="categorySelect" name="category_id" class="form-select">
        <% categories.forEach(cat => { %>
          <option value="<%= cat.id %>"><%= cat.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label" for="statusSelect">ステータス</label>
      <select id="statusSelect" name="status_id" class="form-select">
        <% statuses.forEach(stat => { %>
          <option value="<%= stat.id %>"><%= stat.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="mb-3">
      <label class="form-label" for="infoTextarea">提供情報（Markdown）</label>
      <textarea id="infoTextarea" name="info_md" class="form-control" rows="4" oninput="updatePreview(this.value)"></textarea>
    </div>
    <div class="mb-3">
      <label class="form-label" for="startAtInput">開始日時</label>
      <input id="startAtInput" type="datetime-local" name="start_at" class="form-control" required />
    </div>
    <div class="mb-3">
      <label class="form-label" for="endAtInput">終了日時（継続中の場合は空欄）</label>
      <input id="endAtInput" type="datetime-local" name="end_at" class="form-control" />
    </div>
    <div class="mb-3">
      <label class="form-label">プレビュー</label>
      <div id="preview" class="p-2 border bg-light"></div>
    </div>
    <div class="mb-3">
      <label class="form-label" for="tagsSelect">タグ</label>
      <select id="tagsSelect" name="tags" class="form-select" multiple>
        <% tags.forEach(tag => { %>
          <option value="<%= tag.id %>"><%= tag.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="d-flex align-items-center gap-3">
      <button type="submit" class="btn btn-primary">保存</button>
      <div class="form-check mb-0">
        <input class="form-check-input" type="checkbox" id="discordNotify" name="discord_notify" value="1" />
        <label class="form-check-label" for="discordNotify">Discordに送信</label>
      </div>
    </div>
  </form>

  <hr />
  <h2>障害一覧</h2>
  <table class="table table-bordered table-hover" id="incidentTable">
    <thead>
      <tr>
        <th class="sortable" onclick="sortTable(0, this)">管理番号 <span></span></th>
        <th class="sortable" onclick="sortTable(1, this)">カテゴリ <span></span></th>
        <th class="sortable" onclick="sortTable(2, this)">案件名 <span></span></th>
        <th class="sortable" onclick="sortTable(3, this)">ステータス <span></span></th>
        <th class="sortable" onclick="sortTable(4, this)">タグ <span></span></th>
        <th>日時</th>
        <th>提供情報</th>
        <th>操作</th>
      </tr>
    </thead>
    <tbody>
      <% incidents.forEach(item => { %>
        <tr class="<%= item.is_hidden ? 'table-secondary' : '' %>">
          <td><%= item.code %></td>
          <td><%= item.category %></td>
          <td><%= item.title %></td>
          <td><span class="badge" style="background-color:<%= item.status_color %>;"><%= item.status %></span></td>
          <td>
            <% item.tags.forEach(tag => { %>
              <span class="badge bg-secondary me-1"><%= tag %></span>
            <% }) %>
          </td>
          <td><%= item.start_at %> ～ <%= item.end_at || '継続中' %></td>
          <td><div><%= (item.info_md || '').slice(0, 300) %></div></td>
          <td>
            <button
              class="btn btn-sm btn-outline-primary"
              onclick="editIncidentFromData(this)"
              data-incident-id="<%= item.id %>"
              data-incident-code="<%= item.code %>"
              data-incident-title="<%= item.title %>"
              data-incident-category="<%= item.category_id %>"
              data-incident-status="<%= item.status_id %>"
              data-incident-info="<%= (item.info_md || '').replace(/"/g, '&quot;') %>"
              data-incident-start="<%= item.start_at %>"
              data-incident-end="<%= item.end_at || '' %>"
              data-incident-tags="<%= (item.tag_ids || []).join(',') %>"
            >
              編集
            </button>
            <form method="POST" action="/admin/incidents/hide/<%= item.id %>" class="d-inline">
              <button class="btn btn-sm btn-outline-warning"><%= item.is_hidden ? '表示' : '非表示' %></button>
            </form>
            <form method="POST" action="/admin/incidents/delete/<%= item.id %>" class="d-inline" onsubmit="return confirm('削除してもよろしいですか？');">
              <button class="btn btn-sm btn-outline-danger">削除</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<script>
const updatePreview = md => {
  try {
    document.getElementById('preview').innerHTML = marked.parse(md);
  } catch {
    document.getElementById('preview').innerHTML = '<div class="text-danger">プレビューエラー</div>';
  }
};

const editIncidentFromData = button => {
  try {
    const incident = {
      id: button.dataset.incidentId,
      code: button.dataset.incidentCode,
      title: button.dataset.incidentTitle,
      category_id: button.dataset.incidentCategory,
      status_id: button.dataset.incidentStatus,
      info_md: button.dataset.incidentInfo.replace(/&quot;/g, '"').replace(/\\n/g, '\n'),
      start_at: button.dataset.incidentStart,
      end_at: button.dataset.incidentEnd,
      tag_ids: button.dataset.incidentTags ? button.dataset.incidentTags.split(',') : []
    };

    document.getElementById('incidentId').value = incident.id;
    document.getElementById('titleInput').value = incident.title;
    document.getElementById('categorySelect').value = String(incident.category_id);
    document.getElementById('statusSelect').value = String(incident.status_id);
    document.getElementById('infoTextarea').value = incident.info_md || "";
    document.getElementById('startAtInput').value = incident.start_at ? incident.start_at.slice(0,16) : '';
    document.getElementById('endAtInput').value = incident.end_at ? incident.end_at.slice(0,16) : '';

    const tagSelect = document.getElementById('tagsSelect');
    const tagIds = incident.tag_ids.map(String);
    Array.from(tagSelect.options).forEach(option => {
      option.selected = tagIds.includes(option.value);
    });

    updatePreview(incident.info_md || '');

    const form = document.getElementById('incidentForm');
    form.action = `/admin/incidents/edit/${incident.id}`;

    document.getElementById('editNotice').classList.remove('d-none');
    document.getElementById('editingCode').innerText = incident.code || '';

    // Discord通知チェックを編集時リセット
    document.getElementById('discordNotify').checked = false;

  } catch (error) {
    console.error('編集データの読み込みエラー:', error);
    alert('編集データの読み込みに失敗しました。');
  }
};

const cancelEdit = () => {
  const form = document.getElementById('incidentForm');
  form.reset();
  form.action = "/admin/incidents/add";
  document.getElementById('incidentId').value = '';
  document.getElementById('preview').innerHTML = '';
  document.getElementById('editNotice').classList.add('d-none');

  // Discord通知チェックリセット
  document.getElementById('discordNotify').checked = false;
};

document.getElementById("incidentForm").addEventListener("submit", e => {
  setTimeout(cancelEdit, 100);
});

let sortDir = true;
let currentSortedTh = null;

const sortTable = (colIndex, th) => {
  const table = document.getElementById("incidentTable");
  const rows = Array.from(table.tBodies[0].rows);

  rows.sort((a, b) => {
    const A = a.cells[colIndex].innerText.trim();
    const B = b.cells[colIndex].innerText.trim();
    return sortDir ? A.localeCompare(B) : B.localeCompare(A);
  });

  rows.forEach(row => table.tBodies[0].appendChild(row));

  if (currentSortedTh && currentSortedTh !== th) {
    currentSortedTh.querySelector("span").textContent = '';
  }
  th.querySelector("span").textContent = sortDir ? '▲' : '▼';
  currentSortedTh = th;
  sortDir = !sortDir;
};
</script>

</body>
</html>
