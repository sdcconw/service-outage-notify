ADMIN_USER=user
ADMIN_PASS=
JWT_SECRET=
API_KEY=change-me-api-key
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/
PUBLIC_BASE_URL=https://outage.example.com
PORT=3000
TRUST_PROXY=1
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
PUBLIC_RATE_LIMIT_ENABLED=true
PUBLIC_RATE_LIMIT_WINDOW_MS=60000
PUBLIC_RATE_LIMIT_MAX_REQUESTS=120
PUBLIC_RATE_LIMIT_MESSAGE=アクセスが集中しています。しばらくしてから再試行してください。
LOGIN_RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX_REQUESTS=10
LOGIN_RATE_LIMIT_MESSAGE=ログイン試行回数が上限に達しました。しばらくしてから再試行してください。
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX_REQUESTS=300
API_RATE_LIMIT_MESSAGE=APIのリクエストが上限に達しました。しばらくしてから再試行してください。
PUBLIC_QUERY_CACHE_ENABLED=true
PUBLIC_QUERY_CACHE_TTL_MS=15000
PUBLIC_SEARCH_USE_FTS=true
